// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Car Brands
model CarBrand {
  id          String      @id @default(cuid())
  name        String      @unique
  nameAr      String?
  logo        String?
  country     String?
  isPopular   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  models      CarModel[]
}

// Car Models
model CarModel {
  id          String      @id @default(cuid())
  brandId     String
  brand       CarBrand    @relation(fields: [brandId], references: [id], onDelete: Cascade)
  name        String
  nameAr      String?
  category    String?     // Sedan, SUV, Hatchback, etc.
  basePrice   Float?      // Base price in SAR
  createdAt   DateTime    @default(now())
  years       CarYear[]
  
  @@index([brandId])
}

// Model Years with specific data
model CarYear {
  id          String      @id @default(cuid())
  modelId     String
  model       CarModel    @relation(fields: [modelId], references: [id], onDelete: Cascade)
  year        Int
  priceNew    Float       // New car price in SAR
  createdAt   DateTime    @default(now())
  valuations  CarValuation[]
  
  @@unique([modelId, year])
  @@index([modelId])
}

// Car Valuation Records
model CarValuation {
  id              String      @id @default(cuid())
  carYearId       String
  carYear         CarYear     @relation(fields: [carYearId], references: [id], onDelete: Cascade)
  
  // Car Details
  mileage         Int         // in km
  condition       String      // excellent, good, fair, poor
  color           String?
  fuelType        String?     // petrol, hybrid, electric, diesel
  transmission    String?     // automatic, manual
  bodyType        String?     // sedan, suv, hatchback, coupe
  
  // Calculated Values
  estimatedValue  Float       // Estimated market value in SAR
  minPrice        Float       // Minimum market price
  maxPrice        Float       // Maximum market price
  confidence      Float       // Confidence level 0-1
  
  // Market Data
  marketTrend     String?     // rising, stable, falling
  depreciationRate Float?     // Yearly depreciation rate
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@index([carYearId])
}

// Saved Valuation Requests (for history)
model ValuationRequest {
  id              String      @id @default(cuid())
  
  // User Input
  brand           String
  model           String
  year            Int
  mileage         Int
  condition       String
  color           String?
  fuelType        String?
  transmission    String?
  
  // Result
  estimatedValue  Float
  minPrice        Float
  maxPrice        Float
  confidence      Float
  
  // Metadata
  userAgent       String?
  ipAddress       String?
  
  createdAt       DateTime    @default(now())
  
  @@index([createdAt])
}

// Market Reference Data
model MarketReference {
  id              String      @id @default(cuid())
  category        String      // e.g., "depreciation_rates", "brand_factors"
  key             String
  value           Float
  description     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  @@unique([category, key])
}
