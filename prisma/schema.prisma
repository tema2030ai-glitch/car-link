// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Vehicle data extracted from links or images
model Vehicle {
  id            String   @id @default(cuid())
  brand         String
  model         String
  year          Int?
  trim          String?
  price         Float?
  currency      String   @default("USD")
  
  // Specifications
  engine        String?
  horsepower    Int?
  torque        Int?
  fuelType      String?
  fuelConsumption Float?  // L/100km or MPG
  transmission  String?
  drivetrain    String?
  acceleration  Float?    // 0-100 km/h in seconds
  
  // Dimensions
  length        Float?
  width         Float?
  height        Float?
  weight        Int?
  
  // Features
  safetyFeatures String?  // JSON array
  techFeatures   String?  // JSON array
  
  // Source info
  sourceUrl     String?
  sourceImage   String?   // Base64 or URL
  
  // Market analysis
  marketPrice   Float?
  priceStatus   String?   // good, average, overpriced
  
  // Financing
  monthlyPayment Float?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  comparisons   ComparisonItem[]
  chatSessions  ChatSession[]
}

// Comparison sessions
model Comparison {
  id          String   @id @default(cuid())
  name        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  items       ComparisonItem[]
}

model ComparisonItem {
  id           String     @id @default(cuid())
  comparisonId String
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  vehicleId    String
  vehicle      Vehicle    @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  order        Int        @default(0)
  
  @@index([comparisonId])
}

// Financing offers from banks
model FinancingOffer {
  id            String   @id @default(cuid())
  bankName      String
  bankLogo      String?
  interestRate  Float    // Annual percentage rate
  minDownPayment Float   // Percentage
  maxLoanTerm   Int      // In months
  minLoanAmount Float?
  maxLoanAmount Float?
  fees          Float?   // Processing fees
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Saved chat sessions with AI advisor
model ChatSession {
  id        String   @id @default(cuid())
  messages  String   // JSON array of messages
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
